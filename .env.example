# Copia este fichero como .env y rellena solo los valores necesarios.
# El archivo .env es privado y no se debe subir a Git.

# PostgreSQL local o RDS. Para RDS se recomienda sslmode=require.
DATABASE_URL=postgresql://usuario:password@localhost:5432/pccomponentes_ml

# Direccion de FastAPI usada por Streamlit y por las pruebas.
API_BASE_URL=http://13.61.42.45:8000

# AWS. La autenticacion se realiza con AWS IAM Identity Center.
# No se guardan claves AWS en este archivo.
AWS_REGION=eu-north-1
AWS_S3_BUCKET=pccomponents-bkt

# Ejemplo de inicio de sesion:
# aws sso login --profile nombre-del-perfil
