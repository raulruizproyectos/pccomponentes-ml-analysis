# Copia este fichero a .env y rellena los valores reales.
# Nunca commitees .env (ya está en .gitignore).

# PostgreSQL (local o RDS)
# Para RDS desde Lambda añadir: ?sslmode=require al final de la URL
DATABASE_URL=postgresql://usuario:password@database-1.clsekk40w58y.eu-north-1.rds.amazonaws.com:5432/pccomponentes_ml

# AWS
# 1. Copia este fichero a .env
# 2. Crea un usuario IAM con permisos S3 (o usa credenciales del equipo)
# 3. Ejecuta: python ejecutar_aws.py crear-bucket
AWS_REGION=eu-north-1
AWS_S3_BUCKET=pccomponents-bkt
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Estructura esperada en S3 (misma que local):
#   s3://<bucket>/brutos/ram/
#   s3://<bucket>/procesados/ram/
#   s3://<bucket>/brutos/tarjetas_graficas/
#   s3://<bucket>/procesados/tarjetas_graficas/

# Lambda ETL (S3 -> PostgreSQL)
# python ejecutar_aws.py desplegar-lambda
# python ejecutar_aws.py verificar-lambda
# python ejecutar_aws.py probar-lambda --clave procesados/ram/productos_ram_limpios.json